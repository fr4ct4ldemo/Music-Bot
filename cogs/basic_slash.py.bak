        return await dispatch_message(interaction, embed)
                embed = success_embed("No suitable message for player.playback.playlistLoad")
        return await dispatch_message(interaction, embed), at_front=True)
                texts = await LangHandler.get_lang(interaction.guild.id, "common.status.live", "player.playback.trackLoadPos", "player.playback.trackLoad")

                stream_content = f"`{texts[0]}`" if tracks[0].is_stream else ""
