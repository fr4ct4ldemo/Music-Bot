        embed = success_embed("No suitable message for player.controls.shuffle.success")

    @app_commands.command(name="swap")
        return await dispatch_message(interaction, embed)
    @app_commands.describe(
        position1="The track to swap. Example: 2",
        position2="The track to swap with position1. Example: 1"
    )
    async def swap(self, interaction: discord.Interaction, position1: int, position2: int):
        "Swaps the specified song to the specified song."
        await interaction.response.defer()
        
        player: voicelink.Player = interaction.guild.voice_client
        if not player:
            return embed = error_embed("No active player found.")
        return await dispatch_message(interaction, embed, ephemeral=True)

        track1, track2 = await player.swap_track(position1, position2, interaction.user)        
        embed = success_embed("Swapped tracks in the queue.")
        return await dispatch_message(interaction, embed)
    @app_commands.describe(
        target="The track to move. Example: 2",
        to="The new position to move the track to. Example: 1"
    )
    async def move(self, interaction: discord.Interaction, target: int, to: int):
        "Moves the specified song to the specified position."
        await interaction.response.defer()
        
        player: voicelink.Player = interaction.guild.voice_client
        if not player:
            return embed = error_embed("No active player found.")
        return await dispatch_message(interaction, embed, ephemeral=True)

        moved_track = await player.move_track(target, to, interaction.user)
        embed = success_embed("Moved track in the queue.")
        return await dispatch_message(interaction, embed)
    async def lyrics(self, interaction: discord.Interaction, title: str = "", artist: str = ""):
        "Displays lyrics for the playing track."
        await interaction.response.defer()
        
        if not title:
            player: voicelink.Player = interaction.guild.voice_client
            if not player or not player.is_playing:
                return embed = error_embed("No track is currently playing.")
        return await dispatch_message(interaction, embed, ephemeral=True)
            
            view = LyricsView(name=title, source={_: re.findall(r'.*\n(?:.*\n){,22}', v or "") for _, v in lyrics.items()}, author=interaction.user)
            view.response = await dispatch_message(interaction, await view.build_embed(), view=view)

    @app_commands.command(name="swapdj")
    @app_commands.describe(member="Choose a member to transfer the dj role.")
    async def swapdj(self, interaction: discord.Interaction, member: discord.Member):
        "Transfer dj to another."
        await interaction.response.defer()
        
        player: voicelink.Player = interaction.guild.voice_client
        if not player:
            return embed = error_embed("No active player found.")
        return await dispatch_message(interaction, embed, ephemeral=True):
            return embed = error_embed("No suitable message for voice.connection.notInChannel")
        return await dispatch_message(interaction, embed, ephemeral=True):
            return embed = info_embed("DJ permissions required.")
        return await dispatch_message(interaction, embed, ephemeral=True)

        if member not in player.channel.members:
            return embed = info_embed("No suitable message for permissions.djNotInChannel")
        return await dispatch_message(interaction, embed, ephemeral=True)
    async def autoplay(self, interaction: discord.Interaction):
        "Toggles autoplay mode, it will automatically queue the best songs to play."
        await interaction.response.defer()
        
        player: voicelink.Player = interaction.guild.voice_client
        if not player:
            return embed = error_embed("No active player found.")
        return await dispatch_message(interaction, embed, ephemeral=True)
        player.settings['autoplay'] = check
        embed = info_embed("No suitable message for player.controls.autoplay")
        return await dispatch_message(interaction, embed)
    async def help(self, interaction: discord.Interaction, category: str = "News") -> None:
        "Lists all the commands in Yeetify."
        await interaction.response.defer()
        
        if category not in self.bot.cogs:
            category = "News"
        view = HelpView(self.bot, interaction.user)
        embed = view.build_embed(category)
        view.response = await dispatch_message(interaction, embed, view=view)

    @app_commands.command(name="ping")
    async def ping(self, interaction: discord.Interaction):
        "Test if the bot is alive, and see the delay between your commands and my response."
        await interaction.response.defer()
        
        player: voicelink.Player = interaction.guild.voice_client

        value = await LangHandler.get_lang(interaction.guild.id, "ping.title1", "ping.field1", "ping.title2", "ping.field2")
        
        embed = discord.Embed(color=Config().embed_color)
        embed.add_field(
            name=value[0],
            value=value[1].format(
                "0", "0", self.bot.latency, '😭' if self.bot.latency > 5 else ('😨' if self.bot.latency > 1 else '👌'), "St Louis, MO, United States"
        ))

        if player:
            embed.add_field(
                name=value[2],
                value=value[3].format(
                    player.node._identifier, player.ping, player.node.player_count, player.channel.rtc_region),
                    inline=False
            )

        await dispatch_message(interaction, embed)

async def setup(bot: commands.Bot) -> None:
    await bot.add_cog(Basic(bot))
