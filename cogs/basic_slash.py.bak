    @app_commands.describe(
        position1="Input a position from the queue to be removed.",
        position2="Set the range of the queue to be removed.",
        member="Remove tracks requested by a specific member."
    )
    async def remove(self, interaction: discord.Interaction, position1: int, position2: int = None, member: discord.Member = None):
        "Removes specified track or a range of tracks from the queue."
        await interaction.response.defer()
        
        player: voicelink.Player = interaction.guild.voice_client
        if not player:
            return embed = error_embed("No active player found.")
        return await dispatch_message(interaction, embed, ephemeral=True)

        removed_tracks = await player.remove_track(position1, position2, remove_target=member, requester=interaction.user)
        embed = success_embed("Removed tracks from the queue.")
        return await dispatch_message(interaction, embed)
        
        player: voicelink.Player = interaction.guild.voice_client
        if not player:
            return embed = error_embed("No active player found.")
        return await dispatch_message(interaction, embed, ephemeral=True)

        if not player.current:
            return embed = error_embed("No track is currently playing.")
        return await dispatch_message(interaction, embed, ephemeral=True)
        embed = success_embed("No suitable message for player.controls.forward")
        return await dispatch_message(interaction, embed)
        
        player: voicelink.Player = interaction.guild.voice_client
        if not player:
            return embed = error_embed("No active player found.")
        return await dispatch_message(interaction, embed, ephemeral=True)

        if not player.current:
            return embed = error_embed("No track is currently playing.")
        return await dispatch_message(interaction, embed, ephemeral=True)
        embed = success_embed("No suitable message for player.controls.rewind")
        return await dispatch_message(interaction, embed, ephemeral=True):
            return embed = error_embed("Invalid position specified.")
        return await dispatch_message(interaction, embed, ephemeral=True)
