    @app_commands.command(name="forceplay")
    @app_commands.describe(
        query="Input a query or a searchable link.",
        start="Specify a time you would like to start, e.g. 1:00",
        end="Specify a time you would like to end, e.g. 4:00"
    )
    async def forceplay(self, interaction: discord.Interaction, query: str, start: str = "0", end: str = "0"):
        "Enforce playback using the given URL or query."
        await interaction.response.defer()
        
        player: voicelink.Player = interaction.guild.voice_client
        if not player:
            player = await voicelink.connect_channel(interaction)

        if not player.is_privileged(interaction.user):
            return embed = error_embed("Missing required permissions.")
        return await dispatch_message(interaction, embed, ephemeral=True):
                index = await player.add_track(tracks.tracks, start_time=format_to_ms(start), end_time=format_to_ms(end), at_front=True)
                embed = success_embed("No suitable message for player.playback.playlistLoad")
        return await dispatch_message(interaction, embed)
                await player.add_track(tracks[0], start_time=format_to_ms(start), end_time=format_to_ms(end), at_front=True)

                stream_content = f"`{texts[0]}`" if tracks[0].is_stream else ""

                await dispatch_message(
                    interaction,
                    stream_content + texts[1],
                    tracks[0].title, tracks[0].uri, tracks[0].author, tracks[0].formatted_length,
                )
        finally:
            if player.queue._repeat.mode == voicelink.LoopType.TRACK:
                await player.set_repeat(voicelink.LoopType.OFF)
                
            await player.stop() if player.is_playing else await player.do_next()

    @app_commands.command(name="pause")
    async def pause(self, interaction: discord.Interaction):
        "Pause the music."
        await interaction.response.defer()
        
        player: voicelink.Player = interaction.guild.voice_client
        if not player:
            return embed = error_embed("No active player found.")
        return await dispatch_message(interaction, embed, ephemeral=True):
            if interaction.user in player.pause_votes:
                return embed = info_embed("Vote already cast.")
        return await dispatch_message(interaction, embed, ephemeral=True), required)

        await player.set_pause(True, interaction.user)
        embed = success_embed("Paused the player.")
        return await dispatch_message(interaction, embed, ephemeral=True)

        if not player.is_paused:
            return embed = success_embed("No suitable message for player.controls.resume.error")

        if not player.is_privileged(interaction.user):
            if interaction.user in player.resume_votes:
                return await send_localized_message(interaction")
        return await dispatch_message(interaction, embed, ephemeral=True):
                return embed = success_embed("No suitable message for player.controls.resume.vote")
        return await dispatch_message(interaction, embed)
        embed = success_embed("Resumed the player.")
        return await dispatch_message(interaction, embed)
        
        player: voicelink.Player = interaction.guild.voice_client
        if not player:
            return embed = error_embed("No active player found.")
        return await dispatch_message(interaction, embed, ephemeral=True):
            if interaction.user == player.current.requester:
                pass
            elif interaction.user in player.skip_votes:
                return embed = info_embed("Vote already cast.")
        return await dispatch_message(interaction, embed, ephemeral=True), required)

        if index:
            player.queue.skipto(index)

        embed = success_embed("Skipped the current track.")
        return await dispatch_message(interaction, embed)
        
        player: voicelink.Player = interaction.guild.voice_client
        if not player:
            return embed = error_embed("No active player found.")
        return await dispatch_message(interaction, embed, ephemeral=True):
                return embed = success_embed("No suitable message for player.controls.back.vote")
        return await dispatch_message(interaction, embed)

        embed = success_embed("Went back to the previous track.")
        return await dispatch_message(interaction, embed)
        
        player: voicelink.Player = interaction.guild.voice_client
        if not player:
            return embed = error_embed("No active player found.")
        return await dispatch_message(interaction, embed, ephemeral=True)

        if not player.current or player.position == 0:
            return embed = error_embed("No track is currently playing.")
        return await dispatch_message(interaction, embed, ephemeral=True)
        embed = success_embed("No suitable message for player.controls.seek")
        return await dispatch_message(interaction, embed, ephemeral=True):
            return embed = error_embed("No suitable message for voice.connection.notInChannel")
        return await dispatch_message(interaction, embed, ephemeral=True)
        view = QueueView(player=player, author=interaction.user)
        view.response = await dispatch_message(interaction, await view.build_embed(), view=view)

    @app_commands.command(name="queue_export")
    async def queue_export(self, interaction: discord.Interaction):
        "Exports the entire queue to a text file"
        await interaction.response.defer()
        
        player: voicelink.Player = interaction.guild.voice_client
        if not player:
            return embed = error_embed("No active player found.")
        return await dispatch_message(interaction, embed, ephemeral=True):
            return embed = error_embed("No suitable message for voice.connection.notInChannel")
        return await dispatch_message(interaction, embed, ephemeral=True)
        
        if player.queue.is_empty and not player.current:
            return embed = error_embed("No track is currently playing.")
        return await dispatch_message(interaction, embed, ephemeral=True):
                raw += ","
            total_length += track.length

        temp = "!Remember do not change this file!\n------------->Info<-------------\nGuild: {} ({})\nRequester: {} ({})\nTracks: {} - {}\n------------>Tracks<------------\n".format(
            interaction.guild.name, interaction.guild.id,
            interaction.user.display_name, interaction.user.id,
            len(tracks), format_ms(total_length)
        ) + temp
        temp += raw

        await interaction.followup.send(content="", file=discord.File(StringIO(temp), filename=f"{interaction.guild.id}_Full_Queue.txt"))

